<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const anyRadio = document.getElementById("anyRadio");
  const customRadio = document.getElementById("customRadio");
  const customBox = document.getElementById("customCategories");

  function toggleCategories() {
    if (customRadio.checked) {
      customBox.style.display = "block";
    } else {
      customBox.style.display = "none";
    }
  }

  // run on change
  anyRadio.addEventListener("change", toggleCategories);
  customRadio.addEventListener("change", toggleCategories);

  // run on page load
  toggleCategories();
</script>
</body>
